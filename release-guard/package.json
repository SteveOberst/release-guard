{
  "name": "org.researchy.release-guard",
  "version": "0.2.0",
  "displayName": "Release Guard",
  "description": "Build-time release hardening for Unity. Blocks bad release builds, runs profile-selected components across pre-build/build/post-build events, and supports custom components and plugins.",
  "unity": "2022.3",
  "unityRelease": "0f1",
  "keywords": [
    "build",
    "release",
    "ci",
    "il2cpp",
    "stripping",
    "security",
    "components",
    "hardening"
  ],
  "author": {
    "name": "Researchy Development",
    "url": "https://github.com/SteveOberst"
  },
  "dependencies": {},
  "testDependencies": {
    "com.unity.test-framework": "1.6.0",
    "com.unity.ext.nunit": "2.0.5"
  },
  "samples": [
    {
      "displayName": "Example Plugin",
      "description": "A minimal Release Guard plugin with settings and one custom component.",
      "path": "Samples~/Example Plugin"
    }
  ],
  "documentationUrl": "https://github.com/SteveOberst/release-guard/blob/main/release-guard/Documentation~/index.md",
  "changelogUrl": "https://github.com/SteveOberst/release-guard/blob/main/release-guard/CHANGELOG.md",
  "licensesUrl": "https://github.com/SteveOberst/release-guard/blob/main/release-guard/LICENSE.md",
  "files": [
    "Editor/",
    "Editor.meta",
    "Runtime/",
    "Runtime.meta",
    "Samples~/",
    "Samples~.meta",
    "Documentation~/",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md",
    "package.json"
  ]
}
